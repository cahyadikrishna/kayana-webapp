# Supabase - get from: Dashboard → Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Google Cloud - get from: Console → APIs & Services → Credentials
GOOGLE_API_KEY=your_google_api_key_here

# Admin WhatsApp number in international format, no + or spaces (e.g. 628123456789)
PUBLIC_ADMIN_WA_PHONE=628123456789
